{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SignalScan Finding",
  "type": "object",
  "properties": {
    "finding_id": {"type": "string"},
    "title": {"type": "string"},
    "stage": {"type": "string", "enum": ["S", "I", "G", "N", "A", "L"]},
    "status": {"type": "string", "enum": ["verified", "possible", "best-practice", "needs-review"]},
    "observation": {"type": "string"},
    "source": {"type": "string"},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "evidence_timestamp": {"type": "string", "format": "date-time"},
    "affected_asset": {"type": "string"},
    "trust_or_security_impact": {"type": "string"},
    "commercial_impact": {"type": "string"},
    "urgency": {"type": "string", "enum": ["low", "medium", "high"]},
    "ease_of_repair": {"type": "string", "enum": ["low", "medium", "high"]},
    "confidence": {"type": "string", "enum": ["low", "medium", "high"]},
    "interpretation": {"type": "string"},
    "recommendation": {"type": "string"},
    "owner": {"type": "string"},
    "target_date": {"type": "string", "format": "date"},
    "retest_method": {"type": "string"},
    "limitation": {"type": "string"},
    "sensitive": {"type": "boolean"},
    "disclosure_handling": {"type": "string"}
  },
  "required": [
    "finding_id",
    "title",
    "stage",
    "status",
    "observation",
    "source",
    "evidence",
    "evidence_timestamp",
    "affected_asset",
    "trust_or_security_impact",
    "commercial_impact",
    "urgency",
    "ease_of_repair",
    "confidence",
    "interpretation",
    "recommendation",
    "owner",
    "target_date",
    "retest_method",
    "limitation",
    "sensitive",
    "disclosure_handling"
  ]
}